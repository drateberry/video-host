# Database
DATABASE_URL="file:./dev.db"

# NextAuth
AUTH_SECRET="generate-a-random-32-char-string"
AUTH_URL="http://localhost:3000"
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="your-secure-password"

# AWS S3
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="your-video-bucket"
S3_BUCKET_URL="https://your-video-bucket.s3.us-east-1.amazonaws.com"

# AWS MediaConvert
MEDIACONVERT_ENDPOINT="https://your-endpoint.mediaconvert.us-east-1.amazonaws.com"
MEDIACONVERT_ROLE_ARN="arn:aws:iam::123456789012:role/MediaConvertRole"
TRANSCODE_WEBHOOK_SECRET="a-random-secret-string"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
